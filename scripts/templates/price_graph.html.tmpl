<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ApeTrader Price Simulation Graph</title>
  <style>
    :root {
      --paper: #f4efe6;
      --ink: #2a241e;
      --muted: #6d6257;
      --panel: rgba(255, 251, 244, 0.94);
      --line: #d6c6b2;
      --grid: rgba(109, 98, 87, 0.18);
      --buy-dash: 7 6;
    }
    body {
      margin: 0;
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      background:
        radial-gradient(circle at top right, rgba(42,111,151,0.14), transparent 32%),
        radial-gradient(circle at bottom left, rgba(194,78,63,0.12), transparent 26%),
        linear-gradient(180deg, #fcf8f1 0%, var(--paper) 100%);
    }
    main {
      max-width: 1240px;
      margin: 0 auto;
      padding: 28px 18px 44px;
    }
    h1, h2 {
      margin: 0;
      line-height: 1.05;
    }
    p {
      margin: 0;
      color: var(--muted);
    }
    .intro, .card {
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--panel);
      box-shadow: 0 16px 32px rgba(42,36,30,0.06);
    }
    .intro {
      padding: 24px;
    }
    .intro p + p {
      margin-top: 10px;
    }
    .callout {
      margin-top: 14px;
      padding: 12px 14px;
      border-left: 4px solid #c24e3f;
      background: rgba(194,78,63,0.08);
      border-radius: 12px;
    }
    .legend {
      display: flex;
      gap: 18px;
      margin-top: 16px;
      flex-wrap: wrap;
      font-size: 14px;
    }
    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .legend-line {
      width: 24px;
      height: 0;
      border-top: 3px solid #2a6f97;
      display: inline-block;
    }
    .legend-line.buy {
      border-top-style: dashed;
    }
    .charts {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 22px;
    }
    .card {
      padding: 18px;
    }
    .card h2 {
      text-transform: capitalize;
      font-size: 30px;
      margin-bottom: 8px;
    }
    .meta {
      font-size: 14px;
      margin-bottom: 12px;
    }
    .chart {
      width: 100%;
      height: auto;
      display: block;
      overflow: visible;
    }
    .series-line {
      transition: stroke-width 120ms ease, opacity 120ms ease, filter 120ms ease;
    }
    .series-line.is-active {
      stroke-width: 4;
      filter: drop-shadow(0 0 4px rgba(42, 36, 30, 0.28));
    }
    .series-line.is-dimmed {
      opacity: 0.18;
    }
    .series-hitbox {
      fill: none;
      stroke: transparent;
      stroke-width: 12;
      pointer-events: stroke;
      cursor: pointer;
    }
    .series-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      margin-top: 14px;
      font-size: 14px;
    }
    .series-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border: 1px solid rgba(214,198,178,0.7);
      border-radius: 999px;
      background: rgba(255,255,255,0.55);
      color: var(--ink);
      transition: opacity 120ms ease, transform 120ms ease, border-color 120ms ease, background 120ms ease;
      cursor: pointer;
    }
    .series-chip.is-active {
      transform: translateY(-1px);
      border-color: rgba(42,36,30,0.35);
      background: rgba(255,255,255,0.92);
    }
    .series-chip.is-dimmed {
      opacity: 0.28;
    }
    .swatch {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      display: inline-block;
    }
    .tooltip {
      position: fixed;
      z-index: 20;
      pointer-events: none;
      transform: translate(12px, 12px);
      padding: 8px 10px;
      border: 1px solid rgba(214,198,178,0.9);
      border-radius: 12px;
      background: rgba(42,36,30,0.92);
      color: #fffaf3;
      font-size: 13px;
      line-height: 1.25;
      box-shadow: 0 10px 24px rgba(42,36,30,0.18);
      opacity: 0;
      transition: opacity 90ms ease;
      white-space: nowrap;
    }
    .tooltip.visible {
      opacity: 1;
    }
    @media (max-width: 720px) {
      main {
        padding: 18px 12px 30px;
      }
      .card h2 {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <main>
    <section class="intro">
      <h1>No-Trader Price Simulation</h1>
      <p>This report simulates {{ .Minutes }} minute ticks with no trader interference and plots each item's buy and sell price path inside each town chart.</p>
      <p>Sell prices use solid lines. Buy prices use dashed lines. All lines are generated from the actual market engine using a zero-reputation player context.</p>
      {{ if .StaticPriceNote }}
      <div class="callout">
        Current prices stayed flat during the run. That matches the current engine: price calculation depends on `supply` and `demand`, while the minute tick mostly changes inventory and prosperity.
      </div>
      {{ end }}
      <div class="legend">
        <span class="legend-item"><i class="legend-line"></i>Sell price</span>
        <span class="legend-item"><i class="legend-line buy"></i>Buy price</span>
      </div>
      <p style="margin-top: 14px;">Generated: {{ .GeneratedAt }} from <code>{{ .InputFile }}</code></p>
    </section>

    <section class="charts">
      {{ range .Charts }}
      <article class="card" data-chart-card="true">
        <h2>{{ .TownName }}</h2>
        <p class="meta">
          {{ if .AnySeriesChange }}
          At least one item price moved during the simulation.
          {{ else }}
          All item price lines stayed flat during the simulation.
          {{ end }}
        </p>

        <svg class="chart" viewBox="0 0 840 240" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Simulated price graph for {{ .TownName }}">
          {{ range .YAxisTicks }}
          <line x1="56" y1="{{ printf "%.2f" .Y }}" x2="816" y2="{{ printf "%.2f" .Y }}" stroke="rgba(109,98,87,0.18)" stroke-width="1"/>
          <text x="{{ printf "%.2f" .X }}" y="{{ printf "%.2f" .Y }}" text-anchor="end" dominant-baseline="middle" font-size="11" fill="#6d6257">{{ .Label }}</text>
          {{ end }}
          <line x1="56" y1="18" x2="56" y2="206" stroke="#b7a48f" stroke-width="1.4"/>
          <line x1="56" y1="206" x2="816" y2="206" stroke="#b7a48f" stroke-width="1.4"/>

          {{ range .MinuteLabels }}
          <text x="{{ printf "%.2f" .X }}" y="{{ printf "%.2f" .Y }}" text-anchor="middle" font-size="11" fill="#6d6257">{{ .Label }}</text>
          {{ end }}

          {{ $townName := .TownName }}
          {{ range .Series }}
          <g data-hover-series="true" data-town="{{ $townName }}" data-item="{{ .ItemName }}" data-kind="sell">
            <polyline class="series-line" fill="none" stroke="{{ .Color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="{{ .SellPath }}"/>
            <polyline class="series-hitbox" points="{{ .SellPath }}"/>
          </g>
          <g data-hover-series="true" data-town="{{ $townName }}" data-item="{{ .ItemName }}" data-kind="buy">
            <polyline class="series-line" fill="none" stroke="{{ .Color }}" stroke-width="2" stroke-dasharray="7 6" stroke-linecap="round" stroke-linejoin="round" opacity="0.9" points="{{ .BuyPath }}"/>
            <polyline class="series-hitbox" points="{{ .BuyPath }}"/>
          </g>
          {{ end }}
        </svg>

        <div class="series-legend" aria-label="Item legend for {{ .TownName }}">
          {{ range .LegendRows }}
          <span class="series-chip" data-legend-item="{{ .ItemName }}"><span class="swatch" style="background: {{ .Color }};"></span>{{ .ItemName }}</span>
          {{ end }}
        </div>
      </article>
      {{ end }}
    </section>
  </main>
  <div id="chart-tooltip" class="tooltip" aria-hidden="true"></div>
  <script>
    (() => {
      const tooltip = document.getElementById('chart-tooltip');
      if (!tooltip) return;

      const moveTooltip = (event) => {
        tooltip.style.left = `${event.clientX}px`;
        tooltip.style.top = `${event.clientY}px`;
      };

      const setCardFocus = (card, itemName) => {
        card.querySelectorAll('[data-hover-series]').forEach((seriesGroup) => {
          const line = seriesGroup.querySelector('.series-line');
          if (!line) return;
          const matches = seriesGroup.getAttribute('data-item') === itemName;
          line.classList.toggle('is-active', matches);
          line.classList.toggle('is-dimmed', !matches);
        });

        card.querySelectorAll('[data-legend-item]').forEach((chip) => {
          const matches = chip.getAttribute('data-legend-item') === itemName;
          chip.classList.toggle('is-active', matches);
          chip.classList.toggle('is-dimmed', !matches);
        });
      };

      const clearCardFocus = (card) => {
        card.querySelectorAll('.series-line').forEach((line) => {
          line.classList.remove('is-active', 'is-dimmed');
        });
        card.querySelectorAll('[data-legend-item]').forEach((chip) => {
          chip.classList.remove('is-active', 'is-dimmed');
        });
      };

      document.querySelectorAll('[data-chart-card]').forEach((card) => {
        card.querySelectorAll('[data-hover-series]').forEach((seriesGroup) => {
          const visibleLine = seriesGroup.querySelector('.series-line');
          if (!visibleLine) return;

          const label = seriesGroup.getAttribute('data-item');
          const kind = seriesGroup.getAttribute('data-kind');
          const town = seriesGroup.getAttribute('data-town');

          const show = (event) => {
            setCardFocus(card, label);
            tooltip.innerHTML = `<strong>${label}</strong><br>${kind} price in ${town}`;
            tooltip.classList.add('visible');
            tooltip.setAttribute('aria-hidden', 'false');
            moveTooltip(event);
          };

          const hide = () => {
            clearCardFocus(card);
            tooltip.classList.remove('visible');
            tooltip.setAttribute('aria-hidden', 'true');
          };

          seriesGroup.addEventListener('mouseenter', show);
          seriesGroup.addEventListener('mousemove', moveTooltip);
          seriesGroup.addEventListener('mouseleave', hide);
        });

        card.querySelectorAll('[data-legend-item]').forEach((chip) => {
          const itemName = chip.getAttribute('data-legend-item');
          if (!itemName) return;

          chip.addEventListener('mouseenter', () => {
            setCardFocus(card, itemName);
          });
          chip.addEventListener('mouseleave', () => {
            clearCardFocus(card);
          });
        });
      });
    })();
  </script>
</body>
</html>
