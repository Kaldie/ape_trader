{
  "info": {
    "_postman_id": "cd7ab622-e0f6-4ef2-ada1-0c3388f83a9a",
    "name": "ApeTrader API",
    "description": "Postman collection for testing the ApeTrader economic simulation backend.\n\nFlow: Register Player -> Create Trader -> Market/Trade/Travel endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Players",
      "item": [
        {
          "name": "Register Player",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.player && jsonData.player.id) {",
                  "    pm.collectionVariables.set(\"player_id\", jsonData.player.id);",
                  "}",
                  "if (jsonData.player && jsonData.player.email) {",
                  "    pm.collectionVariables.set(\"player_email\", jsonData.player.email);",
                  "}"
                ]
              }
            }
          ],
          "id": "d297d791-2716-490f-b4de-541b6aeabbf3",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Alice Trader\",\n    \"email\": \"alice@example.com\",\n    \"password\": \"super-secret-123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/players/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "players",
                "register"
              ]
            }
          },
          "response": []
        }
      ],
      "id": "4eac3ca9-cf65-4015-888e-d6cc91bcb407"
    },
    {
      "name": "Traders",
      "item": [
        {
          "name": "Create Trader",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"trader_token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "id": "d18060f9-d847-402f-bc7d-cedaa12fc1c7",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"player_id\": \"{{player_id}}\",\n    \"name\": \"Wood Trader Bot\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/traders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "traders"
              ]
            }
          },
          "response": []
        }
      ],
      "id": "cc2f1b41-6917-4c88-b895-5bf390a0584f"
    },
